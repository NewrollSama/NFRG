{
    "version": 10,
    "configurePresets": [
        {
            "name": "windows-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "windows-msvc-debug",
            "displayName": "Windows MSVC Debug",
            "inherits": "windows-base",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "windows-msvc-release",
            "displayName": "Windows MSVC Release",
            "inherits": "windows-msvc-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "windows-clang-debug",
            "displayName": "Windows Clang Debug",
            "inherits": "windows-base",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang.exe",
                "CMAKE_CXX_COMPILER": "clang++.exe",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "windows-clang-release",
            "displayName": "Windows Clang Release",
            "inherits": "windows-clang-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "linux-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "linux-gcc-debug",
            "displayName": "Linux GCC Debug",
            "inherits": "linux-base",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "linux-gcc-release",
            "displayName": "Linux GCC Release",
            "inherits": "linux-gcc-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "linux-clang-debug",
            "displayName": "Linux Clang Debug",
            "inherits": "linux-base",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "linux-clang-release",
            "displayName": "Linux Clang Release",
            "inherits": "linux-clang-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows-build-base",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "windows-msvc-build",
            "displayName": "Windows MSVC Build",
            "inherits": "windows-build-base",
            "configurePreset": "windows-msvc-release"
        },
        {
            "name": "windows-clang-build",
            "displayName": "Windows MSVC Build",
            "inherits": "windows-build-base",
            "configurePreset": "windows-clang-release"
        },
        {
            "name": "linux-build-base",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "linux-gcc-build",
            "displayName": "Linux GCC Build",
            "inherits": "linux-build-base",
            "configurePreset": "linux-gcc-release"
        },
        {
            "name": "linux-clang-build",
            "displayName": "Linux MSVC Build",
            "inherits": "linux-build-base",
            "configurePreset": "linux-clang-release"
        },
        {
            "name": "linux-gcc-install",
            "displayName": "Linux GCC Install",
            "inherits": "linux-build-base",
            "configurePreset": "linux-gcc-release",
            "targets": [
                "install"
            ]
        },
        {
            "name": "linux-clang-install",
            "displayName": "Linux MSVC Install",
            "inherits": "linux-build-base",
            "configurePreset": "linux-clang-release",
            "targets": [
                "install"
            ]
        }
    ],
    "workflowPresets": [
        {
            "name": "appimage-gcc",
            "displayName": "Pack by AppImage (GCC)",
            "steps": [
                {
                    "type": "configure",
                    "name": "linux-gcc-release"
                },
                {
                    "type": "build",
                    "name": "linux-gcc-build"
                },
                {
                    "type": "build",
                    "name": "linux-gcc-install"
                }
            ]
        },
        {
            "name": "appimage-clang",
            "displayName": "Pack by AppImage (Clang)",
            "steps": [
                {
                    "type": "configure",
                    "name": "linux-clang-release"
                },
                {
                    "type": "build",
                    "name": "linux-clang-build"
                },
                {
                    "type": "build",
                    "name": "linux-clang-install"
                }
            ]
        }
    ]
}